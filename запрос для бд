USE [ShoeShop]
GO

-- Добавляем колонку Phone если её нет
IF NOT EXISTS (SELECT * FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'Users' AND COLUMN_NAME = 'Phone')
BEGIN
    ALTER TABLE Users ADD Phone NVARCHAR(20) NULL
END
GO

-- Обновляем существующих пользователей (если нужно)
UPDATE Users SET Phone = '+70000000000' WHERE Phone IS NULL
GO

-- Делаем Phone обязательным для новых записей
ALTER TABLE Users ALTER COLUMN Phone NVARCHAR(20) NOT NULL
GO

-- Добавляем уникальность для телефона
ALTER TABLE Users ADD CONSTRAINT UQ_Users_Phone UNIQUE (Phone)
GO

