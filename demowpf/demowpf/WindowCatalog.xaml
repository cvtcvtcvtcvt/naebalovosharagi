<Window x:Class="demowpf.WindowCatalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин обуви" Height="580" Width="950"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5" Height="35">
            <TextBox x:Name="txtSearch" Width="160" Margin="0,0,5,0"
                     VerticalContentAlignment="Center"
                     TextChanged="txtSearch_TextChanged"/>
            <ComboBox x:Name="cmbSort" Width="120" Margin="0,0,5,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="cmbSort_Changed">
                <ComboBoxItem Content="По цене ↑" IsSelected="True"/>
                <ComboBoxItem Content="По цене ↓"/>
            </ComboBox>
            <Button Content="Корзина"  Width="70"  Margin="0,0,5,0" Click="btnCart_Click"/>
            <Button Content="Обновить" Width="70"  Margin="0,0,5,0" Click="btnRefresh_Click"/>
            <Button x:Name="btnAdmin"  Content="Админ" Width="60" Margin="0,0,5,0"
                    Visibility="Collapsed" Click="btnAdmin_Click"/>
            <Button x:Name="btnLogin"  Content="Войти" Width="70" Margin="0,0,5,0"
                    Click="btnLogin_Click"/>
            <TextBlock x:Name="lblUser" VerticalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="wrapPanel" Margin="5"/>
        </ScrollViewer>

    </DockPanel>
</Window>