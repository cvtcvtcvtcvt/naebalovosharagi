<Window x:Class="demowpf.WindowAuth"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="30">
        <TextBlock Text="Логин:"/>
        <TextBox x:Name="txtLogin" Margin="0,2,0,8"/>

        <TextBlock Text="Пароль:"/>
        <PasswordBox x:Name="txtPass" Margin="0,2,0,12"/>

        <WrapPanel>
            <Button Content="Войти" Width="80" Click="btnLogin_Click" Margin="0,0,5,0"/>
            <Button Content="Регистрация" Width="100" Click="btnRegister_Click"/>
        </WrapPanel>

        <Button Content="Войти как гость" Margin="0,15,0,0" Click="btnGuest_Click"/>
    </StackPanel>
</Window>