<Window x:Class="demowpf.WindowAdmin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Админ панель" Height="520" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
            <ComboBox x:Name="cmbTable" Width="140" Margin="0,0,5,0"
                      SelectedIndex="0">
                <ComboBoxItem Content="Товары"/>
                <ComboBoxItem Content="Пользователи"/>
            </ComboBox>
            <Button Content="Загрузить" Margin="0,0,5,0" Click="btnLoad_Click"/>
            <Button Content="Добавить" Margin="0,0,5,0" Click="btnAdd_Click"/>
            <Button Content="Сохранить" Margin="0,0,5,0" Click="btnSave_Click"/>
            <Button Content="Удалить" Click="btnDelete_Click"/>
        </StackPanel>
        <DataGrid x:Name="dgv" AutoGenerateColumns="True" CanUserAddRows="False"/>
    </DockPanel>
</Window>
